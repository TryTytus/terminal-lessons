{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://terminal-lessons.local/lesson.schema.json",
  "title": "Terminal Lessons Lesson",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "id", "title", "intro", "workspace", "checks"],
  "properties": {
    "version": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$",
      "minLength": 1,
      "maxLength": 80
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "difficulty": {
      "type": "string",
      "default": "beginner"
    },
    "intro": {
      "type": "string",
      "minLength": 1
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["files"],
      "properties": {
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "content"],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1,
                "not": {
                  "anyOf": [
                    { "pattern": "^/" },
                    { "pattern": "(^|/)\\.\\.(/|$)" },
                    { "pattern": "\\u0000" }
                  ]
                }
              },
              "content": {
                "type": "string",
                "maxLength": 65536
              }
            }
          },
          "default": []
        }
      }
    },
    "hints": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "solution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "commands": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "explanation": {
          "type": "string",
          "default": ""
        }
      },
      "default": {
        "commands": [],
        "explanation": ""
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type"],
        "properties": {
          "type": {
            "enum": [
              "file_exists",
              "file_not_exists",
              "file_equals",
              "file_contains",
              "stdout_contains",
              "stdout_matches"
            ]
          },
          "path": {
            "type": "string"
          },
          "expected": {
            "type": "string",
            "maxLength": 65536
          },
          "pattern": {
            "type": "string"
          },
          "trim": {
            "type": "boolean",
            "default": false
          }
        }
      }
    }
  }
}
