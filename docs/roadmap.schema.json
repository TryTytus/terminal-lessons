{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://terminal-lessons.local/roadmap.schema.json",
  "title": "Terminal Lessons Roadmap",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "id", "title", "summary", "commands"],
  "properties": {
    "version": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$",
      "minLength": 1,
      "maxLength": 80
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "default": ""
    },
    "difficulty": {
      "type": "string",
      "default": "beginner"
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "title", "summary", "guide", "lessons"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "guide": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\.md$",
            "not": {
              "anyOf": [
                { "pattern": "^/" },
                { "pattern": "(^|/)\\.\\.(/|$)" },
                { "pattern": "\\u0000" }
              ]
            }
          },
          "lessons": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "focus"],
              "properties": {
                "id": {
                  "type": "string"
                },
                "path": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "\\.ya?ml$",
                  "not": {
                    "anyOf": [
                      { "pattern": "^/" },
                      { "pattern": "(^|/)\\.\\.(/|$)" },
                      { "pattern": "\\u0000" }
                    ]
                  }
                },
                "focus": {
                  "type": "string",
                  "minLength": 1
                },
                "flag": {
                  "type": "string"
                },
                "kind": {
                  "type": "string",
                  "enum": ["foundation", "parameter", "pattern", "capstone"]
                }
              }
            }
          }
        }
      }
    }
  }
}
